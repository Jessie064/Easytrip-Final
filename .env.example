# -----------------------------------------------------------------------------
# EasyTrip Local Environment Variables File (.env.example)
# -----------------------------------------------------------------------------
# This is a template. Copy this file into a new file named .env
# and fill in the actual values. DO NOT commit actual secrets here.
# -----------------------------------------------------------------------------

# 1. Mapbox API Token (Required for the interactive map to show up)
# Get this for free at: https://www.mapbox.com
MAPBOX_TOKEN=your_mapbox_token_here

# 2. Groq API Key (Required for AI itinerary generation)
# Get this for free at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# 3. Gmail Settings (Required if you want the app to send emails locally)
# NOTE: Use an "App Password", NOT your actual Gmail password.
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here

# 4. Django Security (Already handled, but can be customized here)
DEBUG=True
SECRET_KEY=django-insecure-local-dev-key
SITE_URL=http://127.0.0.1:8000
